
---

# 📦 `.gitignore` (VERY IMPORTANT)

```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
env/
ENV/
.venv/

# Jupyter Notebook
.ipynb_checkpoints/

# Data files
*.csv
*.xlsx
*.json

# Model checkpoints
*.pt
*.pth
*.h5

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Matplotlib
*.png

# Cache
.cache/

# dotenv
.env